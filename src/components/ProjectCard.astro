---
interface Props {
  title: string;
  dayTime: string;
  repoLink: string;
  description: string;
}

const { title, description, repoLink, dayTime } = Astro.props;
---

<a
  href={repoLink}
  target="_blank"
  rel="noopener noreferrer"
  class="flex max-w-lg flex-col justify-between rounded-lg border-2 border-slate-500 px-8 pb-4 pt-8 text-slate-700 shadow-lg drop-shadow-xl transition-all duration-300 hover:shadow-xl hover:shadow-slate-400/50 hover:-translate-y-1 cursor-pointer"
>
  <div>
    <h3 class="text-2xl font-medium text-slate-800">{title}</h3>
    <p class="my-4 text-lg">
      {description}
    </p>
  </div>
  <div class="flex items-center justify-between">
    <strong>{dayTime}</strong>
  </div>
</a>
