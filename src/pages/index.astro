---
import ProjectCard from '../components/ProjectCard.astro';
import BlogList from '../components/BlogList.astro';
import SiteMeta from '../components/SiteMeta.astro';
import WorkCardList from '../components/WorkCardList.astro';
import GithubMarkIcon from '../components/icons/Github-mark-icon.astro';
import LaptopIcon from '../components/icons/Laptop-icon.astro';
import LinkedInIcon from '../components/icons/LinkedIn-icon.astro';
import EmailIcon from '../components/icons/Email-icon.astro';
import { projects } from '../data/projects';
import { ClientRouter } from 'astro:transitions';
import { slide } from 'astro:transitions';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SiteMeta />
    <ClientRouter />
  </head>
  <body class="overflow-x-clip" transition:animate={slide({ duration: '0.2s' })}>
    <section
      class="flex flex-col flex-wrap justify-center gap-20 overflow-hidden bg-slate-800 px-6 py-20 sm:px-20 sm:py-32 md:flex-row lg:gap-32 lg:py-52 xl:px-40"
    >
      <LaptopIcon class="w-full max-w-lg" />
      <div class="flex flex-col justify-center">
        <h1 class="text-left text-5xl font-bold leading-normal text-white sm:text-7xl">
          Hi <span class="animate-wave inline-block">👋</span>, I'm Pulkit Banta
        </h1>
        <p class="text-xl font-semibold text-teal-400 sm:mt-2">Senior Software Engineer — Full Stack</p>
        <p class="mb-3 mt-4 max-w-xl text-base font-normal text-slate-300 sm:mt-6">
          Building AI-powered products with React, TypeScript, and Golang. Focused on LLM integrations, MCP servers,
          scalable architecture, and team leadership.
        </p>
        <a
          href="mailto:pulkitbanta01@gmail.com"
          target="_blank"
          class="mt-4 inline-flex items-center gap-2 text-lg font-semibold text-teal-400 hover:text-teal-300"
        >
          <EmailIcon height={24} width={24} /> pulkitbanta01@gmail.com
        </a>
        <div class="mt-6 flex gap-4">
          <a
            target="_blank"
            href="https://www.github.com/pulkitbanta"
            class="text-slate-200 transition-colors hover:text-white"
          >
            <GithubMarkIcon height={28} width={28} />
          </a>
          <a
            href="https://www.linkedin.com/in/pulkitbanta"
            target="_blank"
            class="text-slate-200 transition-colors hover:text-white"
          >
            <LinkedInIcon height={28} width={28} />
          </a>
        </div>
      </div>
    </section>
    {/* --- Blogs --- */}
    <section class="my-12 px-6 sm:px-20 md:my-40">
      <div class="max-w-270 mx-auto">
        <h2 class="text-center text-4xl font-bold leading-normal sm:text-6xl" transition:name="page-title">
          {'< Blogs />'}
        </h2>
        <p class="mt-3 text-center text-xl font-semibold">Thoughts on software engineering, AI, and more</p>
        <BlogList />
      </div>
    </section>
    {/* --- Work Experience --- */}
    <section class="bg-slate-800 px-6 py-20 text-white sm:px-20 lg:pt-32">
      <div class="max-w-270 mx-auto">
        <h2 class="text-center text-4xl font-bold leading-normal sm:text-6xl">
          {'<'}<wbr /> Work Experience 👷‍♂️ {'/>'}
        </h2>
        <WorkCardList />
      </div>
    </section>
    {/* --- Projects --- */}
    <section class="my-12 px-6 sm:px-20 md:my-40">
      <div class="max-w-270 mx-auto">
        <h2 class="text-center text-4xl font-bold leading-normal sm:text-6xl">{'< Projects />'}</h2>
        <p class="mt-3 text-center text-2xl font-normal">Tools and apps created by me for learning and having fun :)</p>
        <div class="mx-auto flex max-w-6xl flex-wrap justify-center gap-8 py-12 md:py-20">
          {projects.map((project) => <ProjectCard {...project} />)}
        </div>
        <p class="mx-auto w-fit py-2 text-sm font-semibold text-slate-500">Made with ❤️ by Pulkit Banta</p>
      </div>
    </section>
  </body>
</html>
